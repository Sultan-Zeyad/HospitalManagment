@model IEnumerable<HospitalManagment.Models.Patient>
<h2>قائمة المرضى</h2>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary">+ إضافة مريض</a>
        <a asp-action="ExportPdf" asp-route-search="@ViewBag.Search"
           class="btn btn-danger">
            🖨️ تصدير PDF
        </a>
    </div>
    <form method="get" class="d-flex gap-2">
        <input type="text" name="search" value="@ViewBag.Search"
               class="form-control" placeholder="ابحث باسم أو هاتف أو جنس..." style="width:280px;" />
        <button type="submit" class="btn btn-primary">بحث</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
        {
            <a asp-action="Index" class="btn btn-secondary">مسح</a>
        }
    </form>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">لا توجد نتائج للبحث عن "@ViewBag.Search"</div>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>الاسم</th>
                <th>رقم الهاتف</th>
                <th>تاريخ الميلاد</th>
                <th>الجنس</th>
                <th>العمليات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var patient in Model)
            {
                <tr>
                    <td>@patient.FullName</td>
                    <td>@patient.PhoneNumber</td>
                    <td>@patient.DateOfBirth.ToShortDateString()</td>
                    <td>@patient.Gender</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@patient.Id"
                           class="btn btn-warning btn-sm">تعديل</a>
                        <a asp-action="Delete" asp-route-id="@patient.Id"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('هل أنت متأكد؟')">حذف</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <p class="text-muted" style="font-size:12px;">
        إجمالي النتائج: @Model.Count()
    </p>
}
