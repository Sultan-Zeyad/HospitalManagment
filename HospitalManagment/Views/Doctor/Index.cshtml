@model IEnumerable<HospitalManagment.Models.Doctor>

<h2>قائمة الأطباء</h2>

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Create" class="btn btn-primary">+ إضافة طبيب</a>

    <form method="get" class="d-flex gap-2">
        <input type="text" name="search" value="@ViewBag.Search"
               class="form-control" placeholder="ابحث باسم أو بريد..." style="width:220px;" />

        <select name="specialization" class="form-control" style="width:160px;">
            <option value="">كل التخصصات</option>
            @foreach (var spec in ViewBag.Specializations as List<string>)
            {
                <option value="@spec" selected="@(ViewBag.Specialization == spec)">@spec</option>
            }
        </select>

        <button type="submit" class="btn btn-primary">بحث</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string) ||
                !string.IsNullOrEmpty(ViewBag.Specialization as string))
        {
            <a asp-action="Index" class="btn btn-secondary">مسح</a>
        }
    </form>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">لا توجد نتائج</div>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>الاسم</th>
                <th>التخصص</th>
                <th>رقم الهاتف</th>
                <th>البريد الإلكتروني</th>
                <th>العمليات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var doctor in Model)
            {
                <tr>
                    <td>@doctor.FullName</td>
                    <td>@doctor.Specialization</td>
                    <td>@doctor.PhoneNumber</td>
                    <td>@doctor.Email</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@doctor.Id"
                           class="btn btn-warning btn-sm">تعديل</a>
                        <a asp-action="Delete" asp-route-id="@doctor.Id"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('هل أنت متأكد؟')">حذف</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <p class="text-muted" style="font-size:12px;">
        إجمالي النتائج: @Model.Count()
    </p>
}